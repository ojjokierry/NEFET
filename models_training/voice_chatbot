import speech_recognition as sr
import pyttsx3
import time
import datetime
import webbrowser
import random
import os
import sys
import re

class VoiceAssistant:
    def speak(self, text):
        print(f"🤖 AIRO: {text}")
        try:
            engine = pyttsx3.init('sapi5')
            engine.setProperty('rate', 170)
            engine.setProperty('volume', 1.0)
            engine.say(text)
            engine.runAndWait()
            engine.stop()
        except Exception as e:
            print("⚠️ Ошибка TTS:", e)
            speak_windows(text)

class VoiceRecognizer:
    def __init__(self):
        self.recognizer = sr.Recognizer()
        self.microphone = sr.Microphone()
        with self.microphone as source:
            self.recognizer.adjust_for_ambient_noise(source, duration=1)

    def listen(self):
        try:
            with self.microphone as source:
                print("\n🎤 [Слушаю...]")
                audio = self.recognizer.listen(source, timeout=3, phrase_time_limit=5)
            text = self.recognizer.recognize_google(audio, language="ru-RU").lower()
            print(f"👤 Вы: {text}")
            return text
        except:
            return None

class KnowledgeBase:
    def __init__(self):
        self.facts = {
            "космос": "Космос — это бесконечное пространство со звездами и галактиками.",
            "земля": "Земля — третья планета от Солнца.",
            "солнце": "Солнце — звезда в центре нашей системы.",
            "луна": "Луна — спутник Земли.",
            "python": "Python — простой и мощный язык программирования."
        }

        self.jokes = [
            "Программист — это человек, который решает проблему, о существовании которой вы не знали.",
            "Почему Python не ругается? Потому что он добрый.",
            "Сначала баг, потом фича."
        ]

class CommandProcessor:
    def __init__(self, voice):
        self.voice = voice
        self.kb = KnowledgeBase()
        self.user_name = None

    def process(self, text):
        if not text:
            return

        # Имя
        if not self.user_name and "зовут" in text:
            self.user_name = text.split()[-1].title()
            self.voice.speak(f"Приятно познакомиться, {self.user_name}")
            return

        # Привет
        if "привет" in text:
            name = self.user_name if self.user_name else "друг"
            self.voice.speak(f"Привет, {name}!")
            return

        # Время
        if "время" in text:
            now = datetime.datetime.now().strftime("%H:%M")
            self.voice.speak(f"Сейчас {now}")
            return

        # Дата
        if "дата" in text:
            today = datetime.datetime.now().strftime("%d.%m.%Y")
            self.voice.speak(f"Сегодня {today}")
            return

        # Шутка
        if "шут" in text:
            self.voice.speak(random.choice(self.kb.jokes))
            return

        # Факт
        for key in self.kb.facts:
            if key in text:
                self.voice.speak(self.kb.facts[key])
                return

        # Открыть сайт
        if "открой" in text:
            if "ютуб" in text:
                webbrowser.open("https://youtube.com")
                self.voice.speak("Открываю YouTube")
                return

        # Калькулятор
        if "сколько" in text:
            expr = re.sub(r'[^0-9+\-*/().]', '', text)
            try:
                result = eval(expr)
                self.voice.speak(f"Ответ {result}")
            except:
                self.voice.speak("Не могу посчитать")
            return

        # Выход
        if "пока" in text or "стоп" in text:
            self.voice.speak("Пока!")
            os._exit(0)

        self.voice.speak("Я не понял, повтори")

class AIRO:
    def __init__(self):
        self.voice = VoiceAssistant()
        self.recognizer = VoiceRecognizer()
        self.processor = CommandProcessor(self.voice)

    def run(self):
        self.voice.speak("Здравствуйте, я Айро. Как вас зовут?")
        while True:
            command = self.recognizer.listen()
            if command:
                self.processor.process(command)
            time.sleep(0.3)

def speak_windows(text):
    text = text.replace('"', '').replace("'", "")
    os.system(
        f'powershell -Command "Add-Type -AssemblyName System.Speech;'
        f'(New-Object System.Speech.Synthesis.SpeechSynthesizer).Speak(\'{text}\')"'
    )

if __name__ == "__main__":
    AIRO().run()
