def listen_loop():
    """Основной цикл прослушивания"""
    speak("Здравствуйте! Я AIRO, ваш космический ассистент.")
    speak("Как к вам обращаться?")
    while True:
        try:
            with sr.Microphone() as source:
                status_label.config(text="🎤 Слушаю...", fg="#00ffff")
                root.update()

                r.adjust_for_ambient_noise(source, duration=0.5)
                audio = r.listen(source, timeout=5, phrase_time_limit=8)

            status_label.config(text="🔍 Распознаю...", fg="#ffff00")
            root.update()
            try:
                text = r.recognize_google(audio, language="ru-RU").lower()
            except sr.UnknownValueError:
                status_label.config(text="❌ Не распознано", fg="#ff0000")
                root.update()
                time.sleep(0.5)
                continue
            except sr.RequestError as e:
                status_label.config(text="⚠️ Нет интернета", fg="#ff9900")
                root.update()
                time.sleep(2)
                continue
            status_label.config(text="✅ Распознано", fg="#00ff00")
            root.update()
            process_command(text)
        except sr.WaitTimeoutError:
            continue
        except Exception as e:
            print(f"Общая ошибка: {e}")
            status_label.config(text="⚠️ Ошибка", fg="#ff0000")
            root.update()
            time.sleep(1)
            continue
        finally:
            status_label.config(text="🎤 Слушаю...", fg="#00ffff")
            root.update()
