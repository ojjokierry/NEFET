def add_chat(text, speaker="AIRO"):
    chat.config(state='normal')
    if speaker == "AIRO":
        tag = "airo"
        chat.tag_config("airo", foreground="#00ff00")
        prefix = "🤖 AIRO: "
    else:
        tag = "user"
        chat.tag_config("user", foreground="#ff9900")
        prefix = "👤 Вы: "
    chat.insert(tk.END, prefix + text + "\n", tag)
    chat.yview(tk.END)
    chat.config(state='disabled')
def speak(text):
    """Говорить текст"""
    safe = text.replace('"', '').replace("'", "")
    add_chat(text, "AIRO")
    def speak_thread():
        os.system(
            f'powershell -Command "Add-Type -AssemblyName System.Speech; '
            f'(New-Object System.Speech.Synthesis.SpeechSynthesizer).Speak(\'{safe}\')"'
        )
    threading.Thread(target=speak_thread, daemon=True).start()
def wiki_lookup(text):
    try:
        wikipedia.set_lang("ru")
        search_results = wikipedia.search(text, results=2)
        if search_results:
            try:
                summary = wikipedia.summary(search_results[0], sentences=2)
                return f"Из Википедии: {summary}"
            except wikipedia.exceptions.DisambiguationError as e:
                options = e.options[:3]
                return f"Уточните запрос. Возможные варианты: {', '.join(options)}"
            except:
                return f"Нашёл статью '{search_results[0]}', но не могу получить описание."
        return None
    except:
        return None
