def calculate(expression):
    try:
        # Преобразуем русские слова в операторы
        expr = expression.lower()
        replacements = {
            'плюс': '+',
            'минус': '-',
            'умножить на': '*',
            'разделить на': '/',
            'в степени': '**'
        }
        for rus, eng in replacements.items():
            expr = expr.replace(rus, eng)
        result = eval(expr, {"__builtins__": {}}, {})
        return f"Результат: {expression} = {result}"
    except:
        return "Не могу это вычислить"
def process_command(text):
